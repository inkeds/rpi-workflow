{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpi.local/schemas/capability.schema.json",
  "title": "RPI Business Capability",
  "type": "object",
  "required": ["id", "name", "classification", "dependencies", "invariants"],
  "properties": {
    "id": {"type": "string", "pattern": "^CAP-"},
    "name": {"type": "string", "minLength": 1},
    "classification": {"enum": ["core", "supporting", "generic"]},
    "user_outcome": {"type": "string"},
    "source_claims": {"type": "array", "items": {"type": "string"}},
    "status": {"enum": ["candidate", "planned", "active", "implemented", "validated", "retired"]},
    "dependencies": {"type": "array", "items": {"type": "string", "pattern": "^CAP-"}},
    "invariants": {"type": "array", "items": {"type": "string"}},
    "spec_refs": {"type": "array", "items": {"type": "string"}},
    "test_refs": {"type": "array", "items": {"type": "string"}},
    "aliases": {"type": "array", "items": {"type": "string"}},
    "source_changes": {"type": "array", "items": {"type": "string"}},
    "decomposition_review": {"type": "boolean"},
    "decomposition": {
      "type": "object",
      "required": ["status", "reasons", "suggested_slices", "source_changes"],
      "properties": {
        "status": {"enum": ["not_required", "required", "accepted", "resolved"]},
        "reasons": {"type": "array", "items": {"type": "string"}},
        "suggested_slices": {"type": "array", "items": {"type": "string"}},
        "source_changes": {"type": "array", "items": {"type": "string"}}
      }
    },
    "merge_history": {"type": "array", "items": {"type": "object"}},
    "governance_history": {"type": "array", "items": {"type": "object"}},
    "superseded_by": {"type": "string", "pattern": "^CAP-"},
    "split_from": {"type": "string", "pattern": "^CAP-"},
    "split_into": {"type": "array", "items": {"type": "string", "pattern": "^CAP-"}}
  }
}
