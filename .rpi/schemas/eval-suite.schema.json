{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rpi.local/schemas/eval-suite.schema.json",
  "title": "RPI Eval Suite",
  "type": "object",
  "required": ["schema_version", "template", "dataset", "scorers"],
  "properties": {
    "schema_version": {"type": "integer"},
    "suite_id": {"type": "string"},
    "template": {"enum": ["structured-extraction", "grounded-generation", "agent-tool-use"]},
    "dataset": {"type": "object"},
    "scorers": {"type": "array", "minItems": 1},
    "budgets": {"type": "object"}
  }
}
